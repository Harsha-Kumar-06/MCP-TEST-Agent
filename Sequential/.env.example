# ============================================
# AI Research Assistant - Environment Configuration
# ============================================

# Required: Google API Key for Gemini LLM
# Get your key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Optional: Google Custom Search Engine Configuration
# If not provided, DuckDuckGo will be used as fallback (no API key needed)
# To enable Google Custom Search:
# 1. Create a Custom Search Engine: https://programmablesearchengine.google.com/
# 2. Get API Key: https://developers.google.com/custom-search/v1/overview
# GOOGLE_CSE_ID=your_custom_search_engine_id
# GOOGLE_CSE_API_KEY=your_custom_search_api_key

# Optional: Server Configuration
# PORT=8000
# HOST=127.0.0.1

# Optional: Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=INFO

# Optional: Model Configuration
# GEMINI_MODEL=gemini-2.0-flash-exp
# MAX_TOKENS=8192
# TEMPERATURE=0.7
