# Google Gemini API Configuration
# Get your API key from: https://makersuite.google.com/app/apikey

GEMINI_API_KEY=your_api_key_here

# Optional: Model selection (default: gemini-2.5-flash)
# Options: 
#   - gemini-2.5-flash (RECOMMENDED: stable, best price-performance, high-volume tasks)
#   - gemini-3-flash (balanced speed/intelligence)
#   - gemini-2.5-flash-lite (fastest, ultra cost-efficient)
#   - gemini-flash-latest (auto-updates to latest version)
GEMINI_MODEL=gemini-2.5-flash

# Optional: Temperature for response randomness (0.0-1.0)
# Lower = more deterministic, Higher = more creative
GEMINI_TEMPERATURE=0.3

# Optional: Maximum tokens per request
GEMINI_MAX_TOKENS=2048

# Optional: Enable cost tracking
ENABLE_COST_TRACKING=true

# Optional: Enable debug logging
ENABLE_DEBUG_LOGGING=false
