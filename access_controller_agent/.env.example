# Gemini (required for ADK)
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=

# Jira Cloud (optional; if missing, Jira tools return mock/skip)
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=

# Email / SMTP (optional; if missing, send_email logs and returns success mock)
EMAIL_FROM=access-bot@company.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
