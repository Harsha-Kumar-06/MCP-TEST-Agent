# Gemini (required for ADK)
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=

# =============================================================================
# ATLASSIAN CLOUD CREDENTIALS (Jira & Confluence)
# =============================================================================
# These credentials work for Jira and Confluence REST APIs.

# Your Atlassian site URL (e.g., https://yourcompany.atlassian.net)
JIRA_BASE_URL=

# Your Atlassian account email
JIRA_EMAIL=

# API Token from https://id.atlassian.com/manage-profile/security/api-tokens
# This works for Jira and Confluence, but NOT for Bitbucket Cloud API
JIRA_API_TOKEN=

# =============================================================================
# BITBUCKET CLOUD CREDENTIALS (REQUIRED for Bitbucket features)
# =============================================================================
# IMPORTANT: Bitbucket Cloud requires a separate API token with scopes!
# The Atlassian API Token (from id.atlassian.com) does NOT work with Bitbucket.
#
# To create a Bitbucket API Token:
# 1. Go to: https://bitbucket.org/account/settings/api-tokens/
# 2. Click "Create API token"
# 3. Give it a name (e.g., "Access Controller Bot")
# 4. Select these REQUIRED scopes:
#    - Account: Read
#    - Repositories: Read, Write, Admin
#    - Projects: Read, Admin  
#    - Workspaces: Read, Admin
#    - Permissions: Read, Write  <-- CRITICAL for managing user access!
# 5. Click "Create" and copy the token immediately (shown only once)

# Your Atlassian/Bitbucket account email (can be same as JIRA_EMAIL)
BITBUCKET_USERNAME=

# API Token created at https://bitbucket.org/account/settings/api-tokens/
BITBUCKET_API_TOKEN=

# Workspace slug (optional - will be derived from JIRA_BASE_URL if not set)
# (e.g., https://mycompany.atlassian.net -> workspace: mycompany)
BITBUCKET_WORKSPACE=

# =============================================================================
# EMAIL / SMTP (for sending replies)
# =============================================================================
EMAIL_FROM=access-bot@company.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Gmail Configuration (alternative to SMTP)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

