# Campaign Validator Agent - .gitignore
# ----------------------------------------

# Environment variables (never commit real API keys)
.env

# SQLite database (auto-created on first run)
campaign.db
*.db
*.sqlite

# Python cache
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Docker
.dockerignore

# Images are gitignored - place them manually in images/
# Uncomment the line below to ignore all images:
# images/*.jpg
# images/*.jpeg
# images/*.png
# images/*.webp
