# Gmail SMTP Configuration (for sending emails)
# Get App Password from: https://myaccount.google.com/apppasswords
GMAIL_USER=??
GMAIL_APP_PASSWORD=??
FROM_NAME=??

# Company Contact Information (appears in emails)
COMPANY_PHONE=+1-555-0100
COMPANY_WEBSITE=??
BOOKING_LINK=??

# ======================================
# SMS PROVIDER CONFIGURATION
# ======================================
# Choose your SMS provider: twilio | vonage | plivo | textbelt
SMS_PROVIDER=textbelt

# --- TEXTBELT (Recommended for testing - NO ACCOUNT NEEDED) ---
# Free tier: 1 SMS/day (key: "textbelt")
# Paid tier: $0.05/SMS, no restrictions - https://textbelt.com/
TEXTBELT_API_KEY=textbelt

# --- TWILIO ---
# Sign up: https://www.twilio.com/try-twilio
# Free trial: $15 credit, verified numbers only
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- VONAGE (Nexmo) ---
# Sign up: https://dashboard.nexmo.com/sign-up
# Free trial: €2 credit, fewer restrictions than Twilio
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_FROM_NUMBER=

# --- PLIVO ---
# Sign up: https://console.plivo.com/accounts/register/
# Free trial: $0.50 credit, best pricing for high volume
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_FROM_NUMBER=

# Instagram Configuration (for automatic posting)
# Follow INSTAGRAM-QUICK-SETUP.md guide (10 minutes)
# 1. Create Facebook app at developers.facebook.com
# 2. Get access token from Graph API Explorer with permissions: instagram_basic, instagram_content_publish, pages_read_engagement
# 3. Get Account ID: curl "https://graph.facebook.com/v18.0/me/accounts?access_token=YOUR_TOKEN"
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# Optional: OpenAI API Key (for AI content generation)
OPENAI_API_KEY=

# Google ADK (Genkit/Gemini) Configuration - FREE TIER AVAILABLE
# Get API key from: https://aistudio.google.com/apikey
GOOGLE_GENAI_API_KEY=

# Model Options (Latest as of Feb 2026):
# - 'flash' = gemini-2.5-flash (RECOMMENDED - best price-performance, FREE)
# - 'lite'  = gemini-2.5-flash-lite (fastest, FREE)
# - 'pro'   = gemini-2.5-pro (advanced reasoning)
# Note: Gemini 1.5 and 2.0 models are deprecated
GOOGLE_MODEL=flash

# LLM Provider Configuration
# Options: 'auto' (uses Google if available, then OpenAI), 'google', 'openai'
LLM_PROVIDER=auto
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
