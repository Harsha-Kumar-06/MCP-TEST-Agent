# Gmail SMTP Configuration (for sending emails)
# Get App Password from: https://myaccount.google.com/apppasswords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
FROM_NAME=Your Company Name

# Company Contact Information (appears in emails)
COMPANY_PHONE=+1-555-0100
COMPANY_WEBSITE=https://yourcompany.com
BOOKING_LINK=https://calendly.com/yourcompany/demo

# ======================================
# SMS PROVIDER CONFIGURATION
# ======================================
# Choose your SMS provider: twilio | vonage | plivo | textbelt
SMS_PROVIDER=textbelt

# --- TEXTBELT (Recommended for testing - NO ACCOUNT NEEDED) ---
# Free tier: 1 SMS/day (key: "textbelt")
# Paid tier: $0.05/SMS, no restrictions - https://textbelt.com/
TEXTBELT_API_KEY=textbelt

# --- TWILIO ---
# Sign up: https://www.twilio.com/try-twilio
# Free trial: $15 credit, verified numbers only
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- VONAGE (Nexmo) ---
# Sign up: https://dashboard.nexmo.com/sign-up
# Free trial: €2 credit, fewer restrictions than Twilio
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_FROM_NUMBER=

# --- PLIVO ---
# Sign up: https://console.plivo.com/accounts/register/
# Free trial: $0.50 credit, best pricing for high volume
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_FROM_NUMBER=

# ======================================
# INSTAGRAM CONFIGURATION (Automatic Posting)
# ======================================
# Supports: Image posts, Video/Reels, Carousel (multi-image), Stories
# Follow INSTAGRAM-QUICK-SETUP.md guide (10-15 minutes)
#
# IMPORTANT: You need a Facebook Page linked to an Instagram Business/Creator account
#
# Step 1: Create Facebook app at https://developers.facebook.com/apps/create/
#         - Select "Other" → "Business" → Choose "Instagram" use case
#         - Add "Facebook Login for Business" product
#
# Step 2: Get Access Token from Graph API Explorer:
#         - Go to https://developers.facebook.com/tools/explorer/
#         - Select your app, then click "Generate Access Token"
#         - Select permissions: instagram_basic, instagram_content_publish, 
#                               pages_show_list, pages_read_engagement, business_management
#         - Click "Generate Access Token" and complete Facebook Login
#         - IMPORTANT: Select your Facebook Page in the popup!
#         - Token should start with "EAA..." (NOT "IGAA...")
#
# Step 3: Get Instagram Business Account ID:
#         curl "https://graph.facebook.com/v18.0/me/accounts?fields=instagram_business_account&access_token=YOUR_TOKEN"
#         - Copy the "id" inside "instagram_business_account" (format: 17841xxxxxxxxxx)
#
# Step 4: (Optional) Get Long-Lived Token (60 days instead of 1 hour):
#         curl "https://graph.facebook.com/v18.0/oauth/access_token?grant_type=fb_exchange_token&client_id=APP_ID&client_secret=APP_SECRET&fb_exchange_token=SHORT_TOKEN"

INSTAGRAM_ACCESS_TOKEN=EAAxxxxxxx...
INSTAGRAM_ACCOUNT_ID=17841xxxxxxxxxx

# ======================================
# AI IMAGE GENERATION (Optional)
# ======================================
# For automatic Instagram image generation from campaign data
# Leave empty to use placeholder images or provide your own URLs

# Option 1: OpenAI DALL-E (Best quality)
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Option 2: Google Vertex AI Imagen
# Setup: https://console.cloud.google.com/vertex-ai
# Requires: gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# ======================================
# GOOGLE ADK / GEMINI (AI Content Generation)
# ======================================
# Get API key from: https://aistudio.google.com/apikey (FREE!)

GOOGLE_GENAI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxx

# Model Options:
# - 'flash' = gemini-2.5-flash (RECOMMENDED - best price-performance, FREE)
# - 'lite'  = gemini-2.5-flash-lite (fastest, FREE)
# - 'pro'   = gemini-2.5-pro (advanced reasoning)
GOOGLE_MODEL=flash

# LLM Provider Configuration
# Options: 'auto' (uses Google if available, then OpenAI), 'google', 'openai'
LLM_PROVIDER=auto
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
