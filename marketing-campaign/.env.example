# Gmail SMTP Configuration (for sending emails)
# Get App Password from: https://myaccount.google.com/apppasswords
GMAIL_USER=??
GMAIL_APP_PASSWORD=??
FROM_NAME=??

# Company Contact Information (appears in emails)
COMPANY_PHONE=+1-555-0100
COMPANY_WEBSITE=??
BOOKING_LINK=??

# Twilio Configuration (for sending SMS)
# Sign up: https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=??
TWILIO_AUTH_TOKEN=??
TWILIO_PHONE_NUMBER=

# Instagram Configuration (for automatic posting)
# Follow INSTAGRAM-QUICK-SETUP.md guide (10 minutes)
# 1. Create Facebook app at developers.facebook.com
# 2. Get access token from Graph API Explorer with permissions: instagram_basic, instagram_content_publish, pages_read_engagement
# 3. Get Account ID: curl "https://graph.facebook.com/v18.0/me/accounts?access_token=YOUR_TOKEN"
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# Optional: OpenAI API Key (for future AI enhancements)
OPENAI_API_KEY=
