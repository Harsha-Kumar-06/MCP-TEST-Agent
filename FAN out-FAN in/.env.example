# ╔═══════════════════════════════════════════════════════════════════════╗
# ║        LOAN UNDERWRITER - ENVIRONMENT CONFIGURATION                   ║
# ║                                                                       ║
# ║  Quick Setup:                                                         ║
# ║  1. Copy this file: copy .env.example .env                            ║
# ║  2. Get Google API key (see instructions below)                       ║
# ║  3. Replace 'your_google_api_key_here' with your actual key           ║
# ║  4. Run: python main.py                                               ║
# ╚═══════════════════════════════════════════════════════════════════════╝


# ═══════════════════════════════════════════════════════════════════════
# REQUIRED: Google AI API Key (Gemini)
# ═══════════════════════════════════════════════════════════════════════
#
# ┌─────────────────────────────────────────────────────────────────────┐
# │  STEP-BY-STEP: How to Get Your FREE Google API Key                  │
# └─────────────────────────────────────────────────────────────────────┘
#
#   Step 1: Open your browser and go to:
#           https://aistudio.google.com/app/apikey
#
#   Step 2: Sign in with your Google account
#           - Use any Gmail account
#           - If you don't have one, create at gmail.com
#
#   Step 3: Click the "Create API Key" button
#           - You'll see a blue button that says "Create API Key"
#           - Or "+ Create API key in new project"
#
#   Step 4: Copy your API key
#           - It looks like: AIzaSyD-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#           - Click the copy icon next to the key
#
#   Step 5: Paste it below (replace 'your_google_api_key_here')
#
# ┌─────────────────────────────────────────────────────────────────────┐
# │  IMPORTANT NOTES:                                                   │
# │  • The API key is FREE with generous limits                         │
# │  • Keep your API key SECRET - never share it publicly               │
# │  • Never commit .env file to git (it's in .gitignore)               │
# │  • The key starts with "AIza" - ensure you copy the full key        │
# └─────────────────────────────────────────────────────────────────────┘
#
# Example (your key will be different):
# GOOGLE_API_KEY=AIzaSyDxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
GOOGLE_API_KEY=your_google_api_key_here

# ═══════════════════════════════════════════════════════════════════════
# OPTIONAL: Google Cloud / Vertex AI (Advanced Users Only)
# ═══════════════════════════════════════════════════════════════════════
#
# Skip this section if you're using the free AI Studio key above.
# Only use Vertex AI if you need enterprise features.
#
# To use Vertex AI instead:
#   1. Create a Google Cloud account: https://cloud.google.com
#   2. Create a new project in Google Cloud Console
#   3. Enable the "Vertex AI API" for your project
#   4. Set up billing (has free tier)
#   5. Uncomment and fill in the values below:
#
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1


# ═══════════════════════════════════════════════════════════════════════
# OPTIONAL: External API Keys (For Production Use)
# ═══════════════════════════════════════════════════════════════════════
#
# ╔═════════════════════════════════════════════════════════════════════╗
# ║  NOTE: The application works perfectly WITHOUT these keys!          ║
# ║  It uses realistic SIMULATED data for demo purposes.                ║
# ║  Only add real keys if deploying to production.                     ║
# ╚═════════════════════════════════════════════════════════════════════╝
#
# ┌─────────────────────────────────────────────────────────────────────┐
# │  REALTY MOLE API (Property Valuation)                               │
# │  • Website: https://www.realtymole.com                              │
# │  • Sign up: https://rapidapi.com/realtymole/api/realty-mole-property-api │
# │  • Used for: Real property value estimates, rental data             │
# └─────────────────────────────────────────────────────────────────────┘
REALTY_MOLE_API_KEY=mock_key

# ┌─────────────────────────────────────────────────────────────────────┐
# │  ATTOM DATA API (Property Valuation - Alternative)                  │
# │  • Website: https://www.attomdata.com                               │
# │  • Note: Paid alternative with comprehensive property data          │
# │  • Used for: Property details, sales history, valuations            │
# └─────────────────────────────────────────────────────────────────────┘
ATTOM_API_KEY=mock_key

# ┌─────────────────────────────────────────────────────────────────────┐
# │  PLAID API (Credit Reports & Financial Data)                        │
# │  • Website: https://plaid.com                                       │
# │  • Dashboard: https://dashboard.plaid.com                           │
# │  • Docs: https://plaid.com/docs                                     │
# │  • Used for: Credit reports, bank verification, income data         │
# └─────────────────────────────────────────────────────────────────────┘
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here
PLAID_ENV=sandbox

# ┌─────────────────────────────────────────────────────────────────────┐
# │  PERSONA API (Fraud Detection & Identity Verification)              │
# │  • Website: https://withpersona.com                                 │
# │  • Dashboard: https://app.withpersona.com                           │
# │  • Docs: https://docs.withpersona.com                               │
# │  • Used for: Identity verification, document verification, KYC     │
# └─────────────────────────────────────────────────────────────────────┘
PERSONA_API_KEY=your_persona_api_key_here
PERSONA_TEMPLATE_ID=your_persona_template_id_here

# ═══════════════════════════════════════════════════════════════════════
# APPLICATION SETTINGS
# ═══════════════════════════════════════════════════════════════════════
#
# These settings control how the application runs.
# The defaults work fine for most users.
#

# ┌─────────────────────────────────────────────────────────────────────┐
# │  DEBUG MODE                                                         │
# │  • true  = Detailed logging, auto-reload on code changes            │
# │  • false = Minimal logging, better performance                      │
# │  • Recommended: true for development, false for production          │
# └─────────────────────────────────────────────────────────────────────┘
DEBUG=true

# ┌─────────────────────────────────────────────────────────────────────┐
# │  SERVER HOST                                                        │
# │  • 127.0.0.1 = Local access only (recommended for development)      │
# │  • 0.0.0.0   = Allow external access (needed for Docker/deployment) │
# └─────────────────────────────────────────────────────────────────────┘
HOST=127.0.0.1

# ┌─────────────────────────────────────────────────────────────────────┐
# │  SERVER PORT                                                        │
# │  • Default: 8000                                                    │
# │  • Change if port 8000 is already in use                            │
# │  • Access at: http://localhost:PORT                                 │
# └─────────────────────────────────────────────────────────────────────┘
PORT=8000


# ═══════════════════════════════════════════════════════════════════════
# TROUBLESHOOTING
# ═══════════════════════════════════════════════════════════════════════
#
# Problem: "GOOGLE_API_KEY not set" error
# Solution: Make sure you:
#   1. Renamed this file from .env.example to .env
#   2. Replaced 'your_google_api_key_here' with your actual key
#   3. The key starts with 'AIza'
#
# Problem: "Port already in use" error  
# Solution: Change PORT=8000 to PORT=8001 (or another free port)
#
# Problem: "Invalid API key" error
# Solution: 
#   1. Go back to https://aistudio.google.com/app/apikey
#   2. Copy the full key (starts with AIza, ~39 characters)
#   3. Make sure there are no extra spaces
#
# ═══════════════════════════════════════════════════════════════════════
