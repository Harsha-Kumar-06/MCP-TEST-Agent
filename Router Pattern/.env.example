# ============================================================
# HelpDesk Bot - Environment Configuration
# ============================================================

# ===================
# Google AI API Key (Required)
# ===================
GOOGLE_API_KEY=your_google_api_key_here

# Optional: Vertex AI configuration (if using Vertex AI instead of AI Studio)
# GOOGLE_CLOUD_PROJECT=your_project_id
# GOOGLE_CLOUD_LOCATION=us-central1

# ===================
# Application Base URL (Required for specialist chat)
# ===================
# This URL is used to generate specialist chat links
# Specialists receive this URL in notifications to join user chat sessions
APP_BASE_URL=http://localhost:8000

# For production deployment:
# APP_BASE_URL=https://helpdesk.yourcompany.com

# ===================
# Authentication
# ===================
# Set to 'true' to require user login
REQUIRE_AUTH=false

# Authentication method: basic, ldap, sso, oauth_google, oauth_microsoft
AUTH_METHOD=basic

# ===================
# SSO/SAML Configuration (if AUTH_METHOD=sso)
# ===================
# SSO_ENABLED=true
# SSO_PROVIDER=okta
# SSO_ISSUER_URL=https://your-company.okta.com
# SSO_CLIENT_ID=your_client_id
# SSO_CLIENT_SECRET=your_client_secret

# ===================
# LDAP/Active Directory (if AUTH_METHOD=ldap)
# ===================
# LDAP_SERVER=ldap://ldap.company.com:389
# LDAP_USE_SSL=true
# LDAP_BASE_DN=dc=company,dc=com
# LDAP_BIND_DN=cn=service,dc=company,dc=com
# LDAP_BIND_PASSWORD=service_password

# ===================
# OAuth - Google (if AUTH_METHOD=oauth_google)
# ===================
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_REDIRECT_URI=https://helpdesk.company.com/api/auth/callback

# ===================
# OAuth - Microsoft (if AUTH_METHOD=oauth_microsoft)
# ===================
# MICROSOFT_CLIENT_ID=your_azure_app_id
# MICROSOFT_CLIENT_SECRET=your_azure_secret
# MICROSOFT_TENANT_ID=your_tenant_id
# MICROSOFT_REDIRECT_URI=https://helpdesk.company.com/api/auth/callback

# ===================
# Production Settings
# ===================
# SECRET_KEY=your_256_bit_secret_key_for_jwt
# REDIS_URL=redis://localhost:6379
# ALLOWED_ORIGINS=https://helpdesk.company.com

# ============================================================
# HUMAN SPECIALIST NOTIFICATIONS
# ============================================================
# Set to 'true' to enable real Teams/Email notifications
ENABLE_NOTIFICATIONS=true

# ===================
 Microsoft Teams Webhooks
# ===================
# Create Incoming Webhooks in each Teams channel:
# 1. Go to Teams > Select Channel > Connectors > Incoming Webhook
# 2. Name it "HelpDesk Bot" and copy the webhook URL
# TEAMS_WEBHOOK_IT=https://your-company.webhook.office.com/webhookb2/xxx/IncomingWebhook/xxx
# TEAMS_WEBHOOK_HR=https://your-company.webhook.office.com/webhookb2/xxx/IncomingWebhook/xxx
# TEAMS_WEBHOOK_SALES=https://your-company.webhook.office.com/webhookb2/xxx/IncomingWebhook/xxx
# TEAMS_WEBHOOK_LEGAL=https://your-company.webhook.office.com/webhookb2/xxx/IncomingWebhook/xxx

# ===================
 Microsoft Graph API (for direct Teams messages - optional)
# ===================
# Register an app in Azure Portal with these permissions:
# - Chat.ReadWrite, User.Read.All, ChannelMessage.Send
# AZURE_TENANT_ID=your_azure_tenant_id
# AZURE_CLIENT_ID=your_azure_app_client_id
# AZURE_CLIENT_SECRET=your_azure_app_client_secret

# ===================
 Email (SMTP) Configuration
# ===================
# For Microsoft 365:
# SMTP_SERVER=smtp.office365.com
# SMTP_PORT=587
# SMTP_USERNAME=helpdesk@yourcompany.com
# SMTP_PASSWORD=your_app_password_or_oauth_token
# FROM_EMAIL=helpdesk@yourcompany.com
# FROM_NAME=HelpDesk Bot
For Gmail:
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=helpdesk@yourcompany.com
SMTP_PASSWORD=your_app_specific_password

# ============================================================
# SERVICENOW INTEGRATION
# ============================================================
# Enable ServiceNow incident creation
SERVICENOW_ENABLED=false

# Your ServiceNow instance URL (without trailing slash)
SERVICENOW_INSTANCE=https://yourcompany.service-now.com

# Authentication Option 1: Basic Auth (username/password)
SERVICENOW_USERNAME=integration_user
SERVICENOW_PASSWORD=your_integration_password

# Authentication Option 2: OAuth/API Key (preferred for production)
# SERVICENOW_API_KEY=your_oauth_token_or_api_key

# ===================
#  ServiceNow Assignment Groups (must match your ServiceNow groups)
# ===================
SNOW_GROUP_IT=IT Support
SNOW_GROUP_HR=Human Resources
SNOW_GROUP_SALES=Sales Operations
SNOW_GROUP_LEGAL=Legal
# ============================================================
 SPECIALIST DATA SOURCE
# ============================================================
# Choose where to load specialist/expert data from:
#   static      - Use hardcoded fallback data (default, no setup needed)
#   csv         - Load from data/specialists.csv file
#   json        - Load from data/specialists.json file
#   database    - Load from SQLite or PostgreSQL database
#   servicenow  - Load from ServiceNow assignment group members
#   ldap        - Load from Active Directory/LDAP groups

SPECIALIST_SOURCE=csv

# ===================
# File-based Sources (csv, json)
# ===================
SPECIALISTS_CSV_PATH=data/specialists.csv
SPECIALISTS_JSON_PATH=data/specialists.json

# ===================
# Database Source
# ===================
# Type: sqlite or postgresql
SPECIALISTS_DB_TYPE=sqlite
# SQLite: relative or absolute path to .db file
# PostgreSQL: postgresql://user:password@host:port/database
SPECIALISTS_DB_CONNECTION=data/specialists.db

# ===================
# LDAP/Active Directory Source
# ===================
# LDAP_SERVER=ldap://ldap.company.com:389
# LDAP_USE_SSL=true
# LDAP_BASE_DN=dc=company,dc=com
# LDAP_BIND_DN=cn=service,dc=company,dc=com
# LDAP_BIND_PASSWORD=service_password

# AD Group to Department mapping
# AD_GROUP_IT=CN=IT Support,OU=Groups
# AD_GROUP_HR=CN=Human Resources,OU=Groups
# AD_GROUP_SALES=CN=Sales Team,OU=Groups
# AD_GROUP_LEGAL=CN=Legal Department,OU=Groups

# ===================
# Cache Settings
# ===================
# How long to cache specialist data (minutes)
SPECIALISTS_CACHE_TTL=15

# ============================================================
# KNOWLEDGE BASE CONFIGURATION
# ============================================================
# Choose where to load knowledge base articles from:
#   static  - Use built-in sample KB articles (default)
#   json    - Load from JSON file (recommended for customization)
#   csv     - Load from CSV file

KB_SOURCE=json

# ===================
# File Paths
# ===================
KB_JSON_PATH=data/knowledge_base.json
KB_CSV_PATH=data/knowledge_base.csv